# Production Visual Test Environment Variables
# Copy this file to .env.production.local and fill in your credentials
#
# NEVER commit .env.production.local to version control!

# Production deployment URL (current Vercel preview/prod)
BASE_URL=https://phrasongsa-timetable.vercel.app
# Explicit origin for better-auth (matches deployment host)
AUTH_URL=https://phrasongsa-timetable.vercel.app

# Admin credentials for authenticated tests
# Use the admin account created during production seeding
ADMIN_EMAIL=admin@school.local
ADMIN_PASSWORD=admin123

# Target semester for tests
SEMESTER_ID=1-2567

# Skip starting local dev server (use when testing live deployment)
SKIP_WEBSERVER=true

# Path to store auth state
PLAYWRIGHT_AUTH_FILE=playwright/.auth/admin.json

# Azure Communication Services Email (email verification)
# Leave values empty to disable sending (emails still appear in admin Email Outbox UI).
ACS_CONNECTION_STRING=
ACS_SENDER_ADDRESS="DoNotReply@<guid>.azurecomm.net"
