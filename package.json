{
  "name": "school-timetable",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26",
  "scripts": {
    "clean": "rimraf .next .next-test",
    "prebuild": "rimraf .next/types .next-test/types .next/dev/types .next-test/dev/types",
    "dev": "next dev",
    "dev:e2e": "dotenv -e .env.test -- next dev -p 3000",
    "dev:test:local": "dotenv -e .env.test.local -- next dev -p 3000",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "typecheck:watch": "tsc -w -p tsconfig.typecheck.json",
    "validate:tokens": "node scripts/validate-design-tokens.mjs",
    "lint": "pnpm run lint:eslint",
    "lint:eslint": "eslint \"src/**\" --ext .ts,.tsx --report-unused-disable-directives",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:actions": "vitest run -c vitest.actions.config.ts",
    "test:stores": "vitest run -c vitest.store.config.ts",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "dev:db:setup": "pwsh scripts/setup-local-dev-db.ps1",
    "dev:db:setup:seed": "pwsh scripts/setup-local-dev-db.ps1 -Seed",
    "dev:db:up": "docker-compose -f docker-compose.test.yml up -d",
    "dev:db:down": "docker-compose -f docker-compose.test.yml down",
    "test:db:up": "docker-compose -f docker-compose.test.yml up -d",
    "test:db:down": "docker-compose -f docker-compose.test.yml down",
    "test:db:restart": "docker-compose -f docker-compose.test.yml restart",
    "test:db:logs": "docker-compose -f docker-compose.test.yml logs -f postgres-test",
    "test:db:migrate": "dotenv -e .env.test -- prisma migrate deploy",
    "test:db:reset": "dotenv -e .env.test -- prisma migrate reset --force",
    "test:db:seed": "dotenv -e .env.test -- tsx prisma/seed.ts",
    "test:e2e": "node scripts/run-e2e-tests.mjs",
    "test:e2e:prod": "pnpm build && cross-env PROD_BUILD=true node scripts/run-e2e-tests.mjs",
    "test:e2e:manual": "playwright test --timeout=150000",
    "test:e2e:ui": "node scripts/run-e2e-tests.mjs --ui",
    "test:e2e:headed": "node scripts/run-e2e-tests.mjs --headed",
    "test:e2e:debug": "node scripts/run-e2e-tests.mjs --debug",
    "test:e2e:chromium": "playwright test --project=chromium --timeout=150000",
    "test:e2e:publish-happy": "playwright test --config=playwright.config.publish-happy.ts",
    "test:smoke": "playwright test e2e/smoke --timeout=150000",
    "test:smoke:ui": "playwright test e2e/smoke --ui --timeout=150000",
    "test:smoke:headed": "playwright test e2e/smoke --headed --timeout=150000",
    "test:smoke:critical": "playwright test e2e/smoke/critical-smoke.spec.ts --timeout=150000",
    "test:smoke:crud": "playwright test e2e/smoke/crud-smoke.spec.ts --timeout=150000",
    "test:prod:visual": "playwright test --config=playwright.config.prod.ts",
    "test:prod:visual:ui": "playwright test --config=playwright.config.prod.ts --ui",
    "test:prod:visual:update": "playwright test --config=playwright.config.prod.ts --update-snapshots",
    "test:prod:scheduling": "playwright test --config=playwright.config.prod.ts e2e/prod/scheduling",
    "test:prod:crud": "playwright test --config=playwright.config.prod.ts --project=prod-desktop-admin-crud",
    "test:prod:visual:report": "playwright show-report playwright-report-prod",
    "test:moe": "vitest run --config vitest.moe.config.ts __test__/moe-standards/moe-standards.test.ts",
    "test:report": "playwright show-report",
    "test:e2e:ci-mode": "pnpm build && CI=true pnpm test:e2e:manual",
    "ci:show-trace": "pnpm exec playwright show-trace",
    "playwright:install": "playwright install --with-deps chromium",
    "postinstall": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:demo": "dotenv -v SEED_DEMO_DATA=true -- tsx prisma/seed.ts",
    "db:seed:clean": "dotenv -v SEED_CLEAN_DATA=true -- tsx prisma/seed.ts",
    "db:seed:full": "tsx scripts/seed-semester-full.ts",
    "db:studio": "prisma studio",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:backfill:break-groups": "tsx prisma/migration-backfill-break-groups.ts",
    "db:backfill:fundamentals": "tsx prisma/migration-backfill-fundamentals.ts",
    "admin:seed:prod": "tsx scripts/seed-prod-admin.ts",
    "doctor": "npx react-doctor@latest"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.1.1",
    "@mui/material": "^9.1.1",
    "@mui/material-nextjs": "^9.1.1",
    "@mui/x-data-grid": "^9.6.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/extension-accelerate": "^3.0.1",
    "@sparticuz/chromium": "^149.0.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/edge-config": "^1.4.3",
    "@vercel/speed-insights": "^1.3.1",
    "axios": "^1.17.0",
    "better-auth": "^1.6.17",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "lucide-react": "^1.17.0",
    "next": "^16.2.9",
    "notistack": "^3.0.2",
    "pg": "^8.21.0",
    "puppeteer-core": "^25.1.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-icons": "^5.6.0",
    "recharts": "^3.8.1",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.6.0",
    "valibot": "^1.4.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.29.7",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/ui": "^4.1.8",
    "autoprefixer": "^10.5.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-testing-library": "^7.16.2",
    "glob": "^13.0.6",
    "globals": "^16.5.0",
    "happy-dom": "^20.10.2",
    "immer": "^11.1.8",
    "playwright": "^1.60.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "prisma": "^7.8.0",
    "react-doctor": "^0.2.16",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.3.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0",
    "undici": "^8.0.0",
    "vercel": "latest",
    "vite": "^7.3.5",
    "vitest": "^4.1.8"
  },
  "prettier": {
    "semi": true,
    "singleQuote": false,
    "trailingComma": "all",
    "bracketSameLine": false
  }
}
