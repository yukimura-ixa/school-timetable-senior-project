{
  "compilerOptions": {
    "target": "es2023",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "verbatimModuleSyntax": false,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*",
        "./public/*"
      ],
      "@/features/*": [
        "./src/features/*"
      ],
      "@/shared/*": [
        "./src/shared/*"
      ],
      "@/app/*": [
        "./src/app/*"
      ],
      "@/prisma/generated/client": [
        "prisma/generated/client"
      ]
    },
    "forceConsistentCasingInFileNames": true,
    // TypeScript strict mode enabled - incrementally enable additional checks
    // noUnusedLocals/noUnusedParameters disabled: 73 pre-existing sites across the app;
    // re-enable after a dedicated cleanup pass so real type errors aren't drowned out.
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitReturns": true,
    "noUncheckedIndexedAccess": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "proxy.ts",
    "playwright.config.ts",
    "prisma.config.ts",
    "vitest.config.ts",
    "vitest.setup.ts",
    "jest.config.ts",
    "jest.setup.ts",
    "types/**/*.d.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    ".next/dev/dev/types/**/*.ts",
    ".next-test/dev/types/**/*.ts",
    ".next-test/dev/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "legacy/**/*",
    "prisma/**/*",
    "__test__/**/*",
    "e2e/**/*",
    "src/**/*.old.tsx"
  ]
}
