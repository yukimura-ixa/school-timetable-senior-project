{
  "mcpServers": {
    "microsoft/playwright-mcp": {
      "type": "stdio",
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@playwright/mcp@latest"
      ]
    },
    "mui-mcp": {
      "type": "stdio",
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@mui/mcp@latest"
      ]
    },
    "next-devtools": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "next-devtools-mcp@latest"
      ],
      "type": "stdio"
    },
    "Vercel": {
      "url": "https://mcp.vercel.com",
      "type": "http"
    },
    "oraios/serena": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "-p",
        "3.13",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide",
        "--project",
        "B:\\Dev\\school-timetable-senior-project"
      ]
    },
    "context7": {
      "type": "stdio",
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@upstash/context7-mcp@latest"
      ]
    }
  }
}
